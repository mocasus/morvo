<?xml version="1.0" encoding="utf-8"?>
<!-- Morvo — Game Hub (Main screen with Roblox game list) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0a"
    android:paddingHorizontal="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="╔══════════════════╗\n║     M O R V O    ║\n╚══════════════════╝"
        android:textColor="#2ea44f"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="0dp"/>

    <!-- Tier + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvHubTier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="// FREE"
            android:textColor="#6e7681"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/tvHubStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="> ready"
            android:textColor="#6e7681"
            android:textSize="10sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Search -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#111111"
        android:textColor="#e6edf3"
        android:textColorHint="#30363d"
        android:hint="Search games..."
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:singleLine="true"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Game list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGames"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"/>

    <!-- Script Hub button -->
    <Button
        android:id="@+id/btnHubScripts"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="📜 Script Hub"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:textColor="#2ea44f"
        android:backgroundTint="#111111"
        android:layout_marginTop="6dp"/>

</LinearLayout>
