<?xml version="1.0" encoding="utf-8"?>
<!-- Morvo — Script item card -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:padding="12dp"
    android:layout_marginBottom="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvScriptTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="Script Name"
            android:textColor="#e6edf3"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvScriptLang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text=".lua"
            android:textColor="#2ea44f"
            android:textSize="10sp"
            android:background="#0d1117"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvScriptPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="Script preview..."
        android:textColor="#6e7681"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="4dp"/>

</LinearLayout>